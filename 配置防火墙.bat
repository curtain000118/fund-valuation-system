@echo off
chcp 65001 >nul
title 配置防火墙

echo ============================================================
echo 配置防火墙允许访问基金估值系统
echo ============================================================
echo.

netsh advfirewall firewall add rule name="基金估值系统-5000" dir=in action=allow protocol=tcp localport=5000

if %errorlevel% equ 0 (
    echo.
    echo ============================================================
    echo 防火墙配置成功！
    echo ============================================================
    echo.
    echo 手机访问地址: http://192.168.1.3:5000
    echo.
    echo 使用步骤:
    echo   1. 确保手机和电脑连接同一个WiFi
    echo   2. 在手机浏览器输入上面的地址
    echo ============================================================
) else (
    echo 配置失败，请以管理员身份运行此脚本
)

echo.
pause
